@model IEnumerable<ChirayuHospitalMVC.Models.Billing>

@{
    ViewData["Title"] = "Billing";
}

<style>
    .page-wrapper {
        padding: 40px 0;
    }

    .card {
        max-width: 1200px;
        margin: auto;
        padding: 28px 32px;
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    }

    body[data-theme="dark"] .card {
        background: #020617;
        border: 1px solid #1e293b;
    }

    .page-header {
        max-width: 1200px;
        margin: auto;
        margin-bottom: 22px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: #0f172a;
    }

    body[data-theme="dark"] .page-title {
        color: #f8fafc;
    }

    .page-subtitle {
        color: #64748b;
    }

    body[data-theme="dark"] .page-subtitle {
        color: #94a3b8;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .actions-right {
        display: flex;
        gap: 10px;
    }

    .btn-primary {
        background: #2563eb;
        color: #fff;
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
    }

    .btn-secondary {
        background: #e5e7eb;
        color: #111827;
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
    }

    body[data-theme="dark"] .btn-secondary {
        background: #1e293b;
        color: #cbd5e1;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        text-transform: uppercase;
        font-size: 12px;
        color: #64748b;
        padding-bottom: 12px;
        text-align: left;
    }

    body[data-theme="dark"] thead th {
        color: #94a3b8;
    }

    tbody td {
        padding: 14px 0;
        border-top: 1px solid #e5e7eb;
        color: #0f172a;
        font-size: 15px;
    }

    body[data-theme="dark"] tbody td {
        border-color: #1f2937;
        color: #f8fafc;
    }

    .table-total strong {
        color: #2563eb;
        font-weight: 700;
    }

    .table-actions {
        display: flex;
        gap: 8px;
    }

    .btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        text-decoration: none;
        font-size: 16px;
    }

    .btn-view {
        background: #0f172a;
    }

    .btn-edit {
        background: #2563eb;
    }

    .btn-delete {
        background: #ef4444;
    }
</style>

<div class="page-wrapper">

    <div class="page-header">
        <h1 class="page-title">Billing</h1>
        <p class="page-subtitle">View and manage patient billing records</p>
    </div>

    <div class="card">

        <div class="card-header">
            <h2>Billing Records</h2>

            <div class="actions-right">
                <a asp-action="Create" class="btn-primary">
                    <i class="bi bi-plus-lg"></i> Create Bill
                </a>
                <a asp-action="ExportBilling" class="btn-secondary">
                    <i class="bi bi-download"></i> Export CSV
                </a>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Patient</th>
                    <th>Consultation</th>
                    <th>Medicines</th>
                    <th>Treatment</th>
                    <th>Other</th>
                    <th>Total</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var bill in Model)
                {
                    <tr>
                        <td>@bill.Patient?.Name</td>
                        <td>₹@bill.ConsultationFee</td>
                        <td>₹@bill.MedicineCost</td>
                        <td>₹@bill.TreatmentCost</td>
                        <td>₹@bill.AdditionalCharges</td>

                        <td class="table-total">
                            <strong>₹@bill.TotalAmount</strong>
                        </td>

                        <td>@bill.BillingDate.ToString("dd-MMM-yyyy")</td>

                        <td>
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@bill.BillingId"
                                   class="btn-icon btn-view" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a asp-action="Edit" asp-route-id="@bill.BillingId"
                                   class="btn-icon btn-edit" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a asp-action="Delete" asp-route-id="@bill.BillingId"
                                   class="btn-icon btn-delete" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>
