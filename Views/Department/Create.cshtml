@model ChirayuHospitalMVC.Models.Department

@{
    ViewData["Title"] = "Add Department";
}

<div class="page-wrapper">

    <div class="form-card">

        <div class="form-header">
            <h1>Add Department</h1>
            <p>Create a new hospital department</p>
        </div>

        <form asp-action="Create">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="grid">

                <div class="form-group">
                    <label>Department Name</label>
                    <input asp-for="Name" placeholder="Enter department name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <input asp-for="Description" placeholder="Enter description" />
                </div>

            </div>

            <div class="actions">
                <button type="submit" class="btn-primary">Save Department</button>
                <a asp-action="Index" class="btn-secondary">Cancel</a>
            </div>

        </form>

    </div>

</div>


<style>

    .page-wrapper {
        display: flex;
        justify-content: center;
        padding: 60px 20px;
    }

    .form-card {
        width: 100%;
        max-width: 700px;
        background: #ffffff;
        padding: 40px;
        border-radius: 18px;
        box-shadow: 0 25px 50px rgba(0,0,0,.08);
    }

    .form-header {
        margin-bottom: 25px;
    }

        .form-header h1 {
            font-size: 28px;
            margin-bottom: 5px;
        }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    label {
        font-weight: 600;
        margin-bottom: 6px;
    }

    input {
        padding: 12px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
    }

    .actions {
        margin-top: 30px;
        display: flex;
        gap: 12px;
    }

    .btn-primary {
        background: #2563eb;
        color: white;
        padding: 11px 22px;
        border-radius: 10px;
        border: none;
        font-weight: 600;
    }

    .btn-secondary {
        background: #e5e7eb;
        padding: 11px 22px;
        border-radius: 10px;
        text-decoration: none;
        color: #111827;
        font-weight: 600;
    }

</style>