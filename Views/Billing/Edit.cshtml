@model ChirayuHospitalMVC.Models.Billing
@{
    ViewData["Title"] = "Edit Bill";
}

<style>
    .page-wrapper {
        padding: 40px 0;
    }

    .edit-card {
        max-width: 1100px;
        margin: auto;
        background: #ffffff;
        border-radius: 16px;
        padding: 32px 36px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    }

    body[data-theme="dark"] .edit-card {
        background: #020617;
        border: 1px solid #1e293b;
    }

    h1 {
        font-size: 28px;
        margin-bottom: 6px;
    }

    body[data-theme="dark"] h1 {
        color: #f8fafc;
    }

    .subtitle {
        color: #64748b;
        margin-bottom: 26px;
    }

    body[data-theme="dark"] .subtitle {
        color: #94a3b8;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    @@media (max-width: 900px) {
        .grid

    {
        grid-template-columns: 1fr;
    }

    }

    label {
        font-weight: 600;
        margin-bottom: 6px;
        display: block;
    }

    input, select {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
    }

    body[data-theme="dark"] input,
    body[data-theme="dark"] select {
        background: #020617;
        color: #f8fafc;
        border-color: #334155;
    }

    .actions {
        margin-top: 28px;
        display: flex;
        gap: 12px;
    }

    .btn-primary {
        background: #2563eb;
        color: #fff;
        padding: 10px 22px;
        border-radius: 10px;
        border: none;
        font-weight: 600;
    }

    .btn-secondary {
        background: #e5e7eb;
        color: #111827;
        padding: 10px 22px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
    }

    body[data-theme="dark"] .btn-secondary {
        background: #1f2937;
        color: #f8fafc;
    }
</style>

<div class="page-wrapper">
    <div class="edit-card">
        <h1>Edit Bill</h1>
        <div class="subtitle">Update billing information</div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="BillingId" />

            <div class="grid">
                <div>
                    <label>Patient</label>
                    <select asp-for="PatientId" asp-items="ViewBag.PatientId"></select>
                </div>

                <div>
                    <label>Consultation Fee</label>
                    <input asp-for="ConsultationFee" />
                </div>

                <div>
                    <label>Medicine Cost</label>
                    <input asp-for="MedicineCost" />
                </div>

                <div>
                    <label>Treatment Cost</label>
                    <input asp-for="TreatmentCost" />
                </div>

                <div>
                    <label>Additional Charges</label>
                    <input asp-for="AdditionalCharges" />
                </div>
            </div>

            <div class="actions">
                <button type="submit" class="btn-primary">Update</button>
                <a asp-action="Index" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
