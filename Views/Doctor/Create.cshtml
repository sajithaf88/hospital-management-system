@model ChirayuHospitalMVC.Models.Doctor

@{
    ViewData["Title"] = "Add Doctor";
}

<div class="page-wrapper">

    <div class="form-card">

        <div class="form-header">
            <h1>Add Doctor</h1>
            <p>Register a new doctor</p>
        </div>

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="grid">

                <!-- Doctor Name -->
                <div class="form-group">
                    <label>Doctor Name</label>
                    <input asp-for="Name" placeholder="Enter doctor name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- Specialization -->
                <div class="form-group">
                    <label>Specialization</label>
                    <input asp-for="Specialization" placeholder="Enter specialization" />
                </div>

                <!-- Department -->
                <div class="form-group">
                    <label>Department</label>

                    <select asp-for="DepartmentId"
                            asp-items="ViewBag.Departments">

                        <option value="">Select Department</option>

                    </select>

                    <span asp-validation-for="DepartmentId" class="text-danger"></span>
                </div>

                <!-- Contact -->
                <div class="form-group">
                    <label>Contact Number</label>
                    <input asp-for="Contact" placeholder="Phone number" />
                    <span asp-validation-for="Contact" class="text-danger"></span>
                </div>

            </div>

            <div class="actions">
                <button type="submit" class="btn-primary">💾 Save Doctor</button>
                <a asp-action="Index" class="btn-secondary">Cancel</a>
            </div>

        </form>

    </div>

</div>


<style>

    .page-wrapper {
        display: flex;
        justify-content: center;
        padding: 60px 20px;
    }

    .form-card {
        width: 100%;
        max-width: 700px;
        background: #ffffff;
        padding: 40px;
        border-radius: 18px;
        box-shadow: 0 25px 50px rgba(0,0,0,.08);
    }

    body[data-theme="dark"] .form-card {
        background: #020617;
        border: 1px solid #1e293b;
        box-shadow: none;
    }

    .form-header {
        margin-bottom: 25px;
    }

        .form-header h1 {
            font-size: 28px;
            margin-bottom: 5px;
        }

        .form-header p {
            color: #64748b;
        }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    label {
        font-weight: 600;
        margin-bottom: 6px;
        font-size: 14px;
    }

    input, select {
        padding: 12px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        font-size: 14px;
    }

    .actions {
        margin-top: 30px;
        display: flex;
        gap: 12px;
    }

    .btn-primary {
        background: #2563eb;
        color: white;
        padding: 11px 22px;
        border-radius: 10px;
        border: none;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-secondary {
        background: #e5e7eb;
        padding: 11px 22px;
        border-radius: 10px;
        text-decoration: none;
        color: #111827;
        font-weight: 600;
    }

    .text-danger {
        color: #ef4444;
        font-size: 13px;
        margin-top: 3px;
    }

</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}