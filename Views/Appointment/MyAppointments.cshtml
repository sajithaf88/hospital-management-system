@model IEnumerable<ChirayuHospitalMVC.Models.Appointment>
@using ChirayuHospitalMVC.Models

@{
    ViewData["Title"] = "My Appointments";
}

<div class="page-wrapper">

    <div class="page-header">
        <h1>My Appointments</h1>
        <p class="subtitle">Your upcoming doctor visits</p>
    </div>

    <div class="card-container">

        <table class="modern-table">

            <thead>
                <tr>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Doctor</th>
                    <th>Token</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.Date.ToString("dd-MMM-yyyy")</td>

                        <td>@item.Time</td>

                        <td>@item.Doctor?.Name</td>

                        <td>@item.TokenNumber</td>

                        <td>

                            @if (item.Status == AppointmentStatus.Scheduled)
                            {
                                <span class="status scheduled">
                                    Scheduled
                                </span>
                            }

                            else if (item.Status == AppointmentStatus.Completed)
                            {
                                <span class="status completed">
                                    Completed
                                </span>
                            }

                            else if (item.Status == AppointmentStatus.Cancelled)
                            {
                                <span class="status cancelled">
                                    Cancelled
                                </span>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>


<style>

    /* PAGE */

    .page-wrapper {
        padding: 40px 0;
    }

    .page-header h1 {
        font-size: 30px;
        margin-bottom: 5px;
    }

    .subtitle {
        color: #64748b;
    }


    /* CARD */

    .card-container {
        margin-top: 24px;
        border-radius: 18px;
        padding: 28px 32px;
        background: #ffffff;
        box-shadow: 0 20px 40px rgba(0,0,0,.08);
    }


    /* TABLE */

    .modern-table {
        width: 100%;
        border-collapse: collapse;
    }

        .modern-table thead th {
            font-size: 13px;
            text-transform: uppercase;
            color: #64748b;
            padding: 12px;
            text-align: left;
        }

        .modern-table tbody tr {
            border-top: 1px solid #e5e7eb;
            transition: .15s;
        }

            .modern-table tbody tr:hover {
                background: #f8fafc;
            }

        .modern-table td {
            padding: 14px 12px;
        }


    /* STATUS BADGES */

    .status {
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
    }

    .scheduled {
        background: #fef3c7;
        color: #b45309;
    }

    .completed {
        background: #dcfce7;
        color: #166534;
    }

    .cancelled {
        background: #fee2e2;
        color: #991b1b;
    }

</style>