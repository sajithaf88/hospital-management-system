@{
    ViewData["Title"] = "Admin Dashboard";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

    /* ================= THEME VARIABLES ================= */

    body[data-theme="light"] {
        --page-bg: #f1f5f9;
        --card-bg: #ffffff;
        --text-main: #0f172a;
        --text-muted: #64748b;
        --border: #e5e7eb;
    }

    body[data-theme="dark"] {
        --page-bg: #020617;
        --card-bg: #020617;
        --text-main: #e5e7eb;
        --text-muted: #94a3b8;
        --border: #1e293b;
    }


    /* ================= PAGE ================= */

    .page-container {
        padding: 30px;
        font-family: 'Segoe UI',sans-serif;
        background: var(--page-bg);
        min-height: 100vh;
    }

    .page-title {
        font-size: 30px;
        font-weight: 700;
        color: var(--text-main);
    }

    .text-muted {
        color: var(--text-muted);
    }


    /* ================= STAT CARDS ================= */

    .dashboard-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: var(--card-bg);
        border-radius: 18px;
        padding: 25px;
        display: flex;
        align-items: center;
        gap: 18px;
        border: 1px solid var(--border);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: 0.25s;
    }

        .stat-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }

        .stat-card span {
            font-size: 14px;
            color: var(--text-muted);
        }

        .stat-card h2 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
            color: var(--text-main);
        }


    /* ================= ICONS ================= */

    .icon {
        width: 55px;
        height: 55px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
    }

    .blue {
        background: linear-gradient(135deg,#2563eb,#3b82f6);
    }

    .green {
        background: linear-gradient(135deg,#16a34a,#22c55e);
    }

    .orange {
        background: linear-gradient(135deg,#f59e0b,#fbbf24);
    }

    .purple {
        background: linear-gradient(135deg,#7c3aed,#8b5cf6);
    }


    /* ================= CHARTS ================= */

    .dashboard-charts {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
    }

    .chart-card {
        background: var(--card-bg);
        border-radius: 18px;
        padding: 25px;
        border: 1px solid var(--border);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

        .chart-card h3 {
            margin-bottom: 15px;
            color: var(--text-main);
        }

    canvas {
        width: 100% !important;
        height: 350px !important;
    }


    /* ================= TABLE ================= */

    .card {
        background: var(--card-bg);
        padding: 25px;
        border-radius: 18px;
        border: 1px solid var(--border);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        text-align: left;
        font-size: 13px;
        text-transform: uppercase;
        color: var(--text-muted);
        padding-bottom: 12px;
    }

    tbody td {
        padding: 14px 0;
        border-top: 1px solid var(--border);
        color: var(--text-main);
    }


    /* ================= BADGES ================= */

    .badge {
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .scheduled {
        background: #fef3c7;
        color: #92400e;
    }

    .completed {
        background: #dcfce7;
        color: #166534;
    }

    .cancelled {
        background: #fee2e2;
        color: #991b1b;
    }


    /* ================= RESPONSIVE ================= */

    @@media(max-width:900px) {
        .dashboard-charts {
            grid-template-columns: 1fr;
        }
    }

</style>


<div class="page-container">

    <div class="page-header">
        <h1 class="page-title">Admin Dashboard</h1>
        <p class="text-muted">Hospital overview and statistics</p>
    </div>


    <!-- STAT CARDS -->

    <div class="dashboard-cards">

        <div class="stat-card">
            <div class="icon blue">👨‍⚕️</div>
            <div>
                <span>Total Doctors</span>
                <h2>@ViewBag.TotalDoctors</h2>
            </div>
        </div>

        <div class="stat-card">
            <div class="icon green">🧑‍🤝‍🧑</div>
            <div>
                <span>Total Patients</span>
                <h2>@ViewBag.TotalPatients</h2>
            </div>
        </div>

        <div class="stat-card">
            <div class="icon orange">📅</div>
            <div>
                <span>Total Appointments</span>
                <h2>@ViewBag.TotalAppointments</h2>
            </div>
        </div>

        <div class="stat-card">
            <div class="icon purple">💰</div>
            <div>
                <span>Total Revenue</span>
                <h2>₹@ViewBag.TotalRevenue</h2>
            </div>
        </div>

    </div>


    <!-- CHARTS -->

    <div class="dashboard-charts">

        <div class="chart-card">
            <h3>Appointments Last 7 Days</h3>
            <canvas id="appointmentChart"></canvas>
        </div>

        <div class="chart-card">
            <h3>Appointment Status</h3>
            <canvas id="statusChart"></canvas>
        </div>

    </div>


    <!-- RECENT APPOINTMENTS -->

    <div class="card">

        <h3>Recent Appointments</h3>

        <table>

            <thead>
                <tr>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Date</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var a in ViewBag.RecentAppointments)
                {
                    <tr>

                        <td>@a.Patient?.Name</td>
                        <td>@a.Doctor?.Name</td>
                        <td>@a.Date.ToString("dd MMM yyyy")</td>

                        <td>

                            @if (a.Status.ToString() == "Scheduled")
                            {
                                <span class="badge scheduled">Scheduled</span>
                            }
                            else if (a.Status.ToString() == "Completed")
                            {
                                <span class="badge completed">Completed</span>
                            }
                            else
                            {
                                <span class="badge cancelled">Cancelled</span>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>


<script>

    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartLabels));
    const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartData));
    const statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusData));

    /* APPOINTMENT CHART */

    new Chart(document.getElementById("appointmentChart"),{

        type:'line',

        data:{
            labels:labels,
            datasets:[{
                label:'Appointments',
                data:data,
                borderColor:'#2563eb',
                backgroundColor:'rgba(37,99,235,0.15)',
                fill:true,
                tension:0.4
            }]
        },

        options:{
            plugins:{legend:{display:false}}
        }

    });


    /* STATUS CHART */

    new Chart(document.getElementById("statusChart"),{

        type:'doughnut',

        data:{
            labels:["Scheduled","Completed","Cancelled"],
            datasets:[{
                data:statusData,
                backgroundColor:["#f59e0b","#16a34a","#ef4444"]
            }]
        },

        options:{
            plugins:{legend:{position:'bottom'}}
        }

    });

</script>