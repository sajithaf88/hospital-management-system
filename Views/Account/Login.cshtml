@model ChirayuHospitalMVC.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Login - Chirayu Hospital</title>

    <link rel="stylesheet" href="~/css/login.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
</head>

<body class="login-body">

    <div class="login-wrapper">

        <div class="login-card">

            <div class="login-logo">C</div>

            <h2>Chirayu Hospital</h2>
            <p class="login-subtitle">Welcome back! Please login to continue.</p>

            <!-- SUCCESS MESSAGE -->
            @if (TempData["Success"] != null)
            {
                <div style="color:green; margin-bottom:10px; text-align:center;">
                    @TempData["Success"]
                </div>
            }

            <!-- VALIDATION ERRORS -->
            <div asp-validation-summary="All" style="color:red;"></div>

            <form asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="input-group">
                    <i class="bi bi-person-fill"></i>
                    <input asp-for="Username" placeholder="Username" required />
                </div>

                <div class="input-group">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="Password" placeholder="Password" type="password" required />
                </div>

                <button type="submit" class="login-btn">Login</button>

                <div class="login-footer">
                    <a asp-controller="Account" asp-action="Register">Create an account</a>
                </div>
            </form>

        </div>

    </div>

</body>
</html>